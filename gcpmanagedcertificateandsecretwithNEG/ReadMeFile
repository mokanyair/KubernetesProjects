###Create Namespace
kubectl create namespace database
kubectl create namespace web

###Create Secret in Secret Manager
gcloud secrets create postgres-password \
--replication-policy="automatic"

###Add password:
echo -n "MyDBPassword123" | \
gcloud secrets versions add postgres-password --data-file=-

###Verify
gcloud secrets versions access latest --secret=postgres-password

###Install Secrets Store CSI Driver
kubectl apply -f https://github.com/kubernetes-sigs/secrets-store-csi-driver/releases/latest/download/secrets-store-csi-driver.yaml
###Install GCP provider plugin
kubectl apply -f https://raw.githubusercontent.com/GoogleCloudPlatform/secrets-store-csi-driver-provider-gcp/main/deploy/provider-gcp-plugin.yaml

### If the above CSI Driver installation fails, 
# 1Add Helm repo
helm repo add secrets-store-csi-driver https://kubernetes-sigs.github.io/secrets-store-csi-driver/charts

# 2️Update repos
helm repo update

# 3️Install driver with CRDs
helm upgrade --install csi-secrets-store secrets-store-csi-driver/secrets-store-csi-driver \
  --namespace kube-system \
  --create-namespace \
  --set syncSecret.enabled=true \
  --set linux.crds.enabled=true \
  --set enableSecretRotation=true \
  --set rotationPollInterval=2m
###Install GCP provider plugin
kubectl apply -f https://raw.githubusercontent.com/GoogleCloudPlatform/secrets-store-csi-driver-provider-gcp/main/deploy/provider-gcp-plugin.yaml

