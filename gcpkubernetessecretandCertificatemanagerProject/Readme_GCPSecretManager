####GCP Secret Manager: Stores arbitrary secrets like database passwords or API keys#
1. Create a secret in GCP Secret Manager for your database password
   # # Step 1a: Create a secret
gcloud secrets create postgres-password \
  --replication-policy="automatic" \
  --data-file=<(echo -n "MyDBPassword123")
  # Test: gcloud secrets versions access latest --secret=postgres-password

2. Create a self-signed certificate for Nginx

  # # Generate self-signed cert
openssl req -x509 -nodes -days 365 \
  -newkey rsa:2048 \
  -keyout nginx.key \
  -out nginx.crt \
  -subj "/CN=app.deeptechexpertconsulting.com" 

3. Upload to GCP Certificate Manager:
   # gcloud certificate-manager certificates create nginx-selfsigned \
  --certificate-file=nginx.crt \
  --private-key-file=nginx.key \
  --project=gke-new-2026

4. Deploy Postgres database using Secret Manager password
   
   reate a Kubernetes secret from GCP Secret Manager

  # kubectl create secret generic postgres-k8s-secret \
  --from-literal=dbpassword=$(gcloud secrets versions access latest --secret=postgres-password) \
  -n database

5. Ingress with GCP-managed certificate (via annotation)
  apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: nginx-ingress
  namespace: web
  annotations:
    kubernetes.io/ingress.class: "gce"  # Use GCP Ingress controller
    networking.gke.io/managed-certificates: "nginx-selfsigned"  # Certificate Manager reference
spec:
  rules:
  - host: example.com
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: nginx-svc
            port:
              number: 80 
